---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import QuickAnswer from '@/components/QuickAnswer.astro';
import CTASection from '@/components/CTASection.astro';

export async function getStaticPaths() {
  const conditions = await getCollection('conditions');
  return conditions.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---

<BaseLayout title={d.seoTitle ?? d.title} description={d.description} path={`/condicoes/${entry.id}`}>
  <Breadcrumbs
    items={[
      { label: 'Início', href: '/' },
      { label: 'Dificuldades atendidas', href: '/condicoes' },
      { label: d.title, href: `/condicoes/${entry.id}` },
    ]}
  />

  <article class="container-page max-w-3xl py-10">
    <h1 class="font-display text-4xl font-semibold text-brand-800">{d.title}</h1>

    <div class="mt-6">
      <QuickAnswer><p>{d.summary}</p></QuickAnswer>
    </div>

    {d.signs.length > 0 && (
      <div class="mt-8 rounded-2xl border border-accent-400/40 bg-accent-400/10 p-6">
        <h2 class="font-display text-xl font-semibold text-brand-800">Sinais que merecem atenção</h2>
        <ul class="mt-4 space-y-2">
          {d.signs.map((s) => (
            <li class="flex items-start gap-2.5 text-ink/90">
              <svg class="mt-1 h-4 w-4 shrink-0 text-accent-600" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.7 13.3l-3-3 1.4-1.4 1.6 1.6 4-4 1.4 1.4-5.4 5.4z"/></svg>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="prose mt-8 max-w-none">
      <Content />
    </div>
  </article>

  <CTASection
    heading={`Seu filho apresenta sinais de ${d.title.toLowerCase()}?`}
    message={`Olá, Thais! Percebi alguns sinais relacionados a ${d.title.toLowerCase()} e gostaria de conversar.`}
  />
</BaseLayout>
