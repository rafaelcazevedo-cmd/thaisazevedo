---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Section from '@/components/Section.astro';
import ConditionCard from '@/components/ConditionCard.astro';
import CTASection from '@/components/CTASection.astro';
import { site } from '@/config/site';

const conditions = (await getCollection('conditions')).sort((a, b) => a.data.order - b.data.order);

const title = `Dificuldades de aprendizagem atendidas em ${site.city}`;
const description = `Dislexia, TDAH, Discalculia e outras dificuldades de aprendizagem: conheça os sinais e como a neuropsicopedagogia em ${site.city} pode ajudar seu filho.`;
---

<BaseLayout title={title} description={description} path="/condicoes">
  <Breadcrumbs items={[{ label: 'Início', href: '/' }, { label: 'Dificuldades atendidas', href: '/condicoes' }]} />

  <Section eyebrow="Dificuldades atendidas" title="Quando procurar uma neuropsicopedagoga">
    <p class="mb-10 max-w-2xl text-lg text-muted">
      Muitas dificuldades de aprendizagem passam despercebidas e são confundidas com falta de esforço. Conheça as
      principais e seus sinais, identificar cedo faz toda a diferença.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {conditions.map((c) => (
        <ConditionCard title={c.data.title} summary={c.data.summary} href={`/condicoes/${c.id}`} />
      ))}
    </div>
  </Section>

  <CTASection heading="Reconheceu algum desses sinais?" text="Se você identificou sinais no seu filho, vamos conversar. O primeiro contato é sem compromisso." />
</BaseLayout>
