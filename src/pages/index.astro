---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import ConditionCard from '@/components/ConditionCard.astro';
import FAQ from '@/components/FAQ.astro';
import CTASection from '@/components/CTASection.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import PhotoCarousel from '@/components/PhotoCarousel.astro';
import { site } from '@/config/site';
import { faqs } from '@/data/faqs';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const conditions = (await getCollection('conditions')).sort((a, b) => a.data.order - b.data.order);
// Homepage "Especialidades" grid: 5 cards. The other conditions stay live on /condicoes (and their own pages) for SEO.
const especialidadeIds = ['dificuldade-de-aprendizagem', 'tdah', 'tea-autismo', 'sindrome-de-down', 'altas-habilidades'];
const homeEspecialidades = especialidadeIds
  .map((id) => conditions.find((c) => c.id === id))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

// Hero carousel photos (portrait shots, fit the 4:5 frame cleanly).
const heroPhotos = [
  { src: '/images/atendimento-1.jpg', alt: 'Thais Azevedo em um momento de acolhimento com uma criança' },
  { src: '/images/atendimento-2.jpg', alt: 'Thais Azevedo com uma criança que usa fones de cancelamento de ruído' },
  { src: '/images/thais-instituto.jpg', alt: 'Thais Azevedo em ação de inclusão com jovens neurodivergentes' },
];

// "Cada criança aprende de um jeito": static photo showcase (real session photos).
const momentosFotos = [
  { src: '/images/aprende-leitura.jpg', alt: 'Criança trabalhando a leitura com cartões de palavras durante o atendimento' },
  { src: '/images/aprende-escrita.jpg', alt: 'Criança escrevendo e criando uma história no caderno durante o atendimento' },
  { src: '/images/aprende-matematica.jpg', alt: 'Criança resolvendo uma atividade de matemática durante o atendimento' },
  { src: '/images/aprende-atencao.jpg', alt: 'Criança concentrada em uma atividade de atenção, marcando símbolos em uma folha' },
];

// "Reconhece alguma dessas situações?", everyday signs that bring parents in.
const moments = [
  'As notas caíram sem explicação',
  'A lição virou guerra todo dia',
  'Não consegue se concentrar',
  '“Ele diz que é burro”',
  'Está difícil fazer amigos',
  'Não quer ir à escola',
  'Trava na hora da prova',
  'Evita ler em voz alta',
];

const title = `Neuropsicopedagoga em ${site.city} | ${site.brand}`;
const description = `${site.profession} em ${site.city}: avaliação e intervenção neuropsicopedagógica para crianças e adolescentes com dificuldade de aprendizagem, Dislexia, TDAH e Discalculia. Agende pelo WhatsApp.`;
---

<BaseLayout title={title} description={description} path="/">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- atmospheric blobs -->
    <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <div class="drift absolute -left-24 top-10 h-72 w-72 rounded-full bg-brand-300/30 blur-3xl"></div>
      <div class="drift absolute right-0 top-40 h-80 w-80 rounded-full bg-accent-300/40 blur-3xl" style="animation-delay:-6s"></div>
    </div>

    <div class="container-page grid items-center gap-x-10 gap-y-8 py-16 sm:py-24 lg:grid-cols-2">
      <div class="order-1 lg:col-start-1 lg:row-start-1">
        <p class="reveal reveal-1 mb-4 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-paper/70 px-4 py-1.5 text-sm font-semibold text-brand-700 backdrop-blur">
          <span class="h-2 w-2 rounded-full bg-accent-500"></span>
          Em {site.city} · consultório ou atendimento domiciliar
        </p>
        <h1 class="reveal reveal-2 font-display text-3xl font-semibold leading-[1.05] text-brand-800 text-balance break-words sm:text-5xl lg:text-6xl">
          Um trabalho individualizado, com muito <span class="ink-underline">acolhimento e vínculo</span>
        </h1>
        <p class="reveal reveal-3 mt-6 max-w-xl text-lg leading-relaxed text-ink/90">
          Sou <strong>{site.professionalName}</strong>, {site.profession.toLowerCase()} em {site.city}.
          Faço <strong>avaliação e intervenção neuropsicopedagógica</strong> para crianças e adolescentes,
          incluindo crianças neurodivergentes (como Autismo, TDAH e Síndrome de Down), com Dislexia,
          Discalculia e outras dificuldades de aprendizagem.
          Cada criança no seu tempo, e <strong>não é preciso ter diagnóstico</strong> para começar.
        </p>
      </div>

      <div class="reveal reveal-3 relative order-2 lg:col-start-2 lg:row-span-2 lg:row-start-1">
        <PhotoCarousel slides={heroPhotos} />
      </div>

      <div class="reveal reveal-4 order-3 flex flex-col gap-3 sm:flex-row lg:col-start-1 lg:row-start-2">
        <WhatsAppButton size="lg" label="Agendar uma conversa" />
        <a
          href="/servicos"
          class="inline-flex items-center justify-center rounded-full border-2 border-brand-300 px-7 py-4 text-lg font-semibold text-brand-700 transition-colors hover:bg-brand-50"
        >
          Conhecer os serviços
        </a>
      </div>
    </div>
  </section>

  <!-- O que é neuropsicopedagogia? (spotlight feature) -->
  <section class="py-12 sm:py-16">
    <div class="container-page">
      <div class="grid items-center gap-8 rounded-3xl border border-brand-200 bg-gradient-to-br from-brand-100 via-brand-50 to-accent-300/40 p-8 sm:gap-12 sm:p-12 lg:grid-cols-[0.85fr_1.15fr]">
        <div class="order-2 mx-auto w-full max-w-[260px] lg:order-1">
          <div class="aspect-[4/5] overflow-hidden rounded-2xl border border-brand-200 shadow-md">
            <img
              src="/images/hero.svg"
              alt="Ilustração de um livro, um coração e uma planta crescendo, representando acolhimento e aprendizagem"
              width="640"
              height="800"
              loading="lazy"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="font-display text-3xl font-semibold text-brand-800 sm:text-4xl">O que é neuropsicopedagogia?</h2>
          <p class="mt-5 font-display text-2xl leading-snug text-brand-700">
            A <strong class="font-semibold">neuropsicopedagogia</strong> é como uma{' '}
            <span class="ink-underline">mistura de professora particular com psicóloga</span>.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-ink/90">
            Avalia e intervém nas dificuldades de aprendizagem, sempre levando em conta as emoções e o modo único
            de cada criança aprender. Um trabalho individualizado, com muito acolhimento.
          </p>
          <div class="mt-6">
            <WhatsAppButton
              message="Olá, Thais! Gostaria de entender como a neuropsicopedagogia pode ajudar a minha criança."
              label="Tirar minhas dúvidas no WhatsApp"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cada criança aprende de um jeito: static photo showcase, logo após "O que é" -->
  <Section eyebrow="Na prática" title="Cada criança aprende de um jeito" narrow>
    <ul role="list" class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      {momentosFotos.map((f) => (
        <li class="aspect-[4/5] overflow-hidden rounded-2xl border border-brand-100 shadow-sm">
          <img src={f.src} alt={f.alt} width="640" height="800" loading="lazy" class="h-full w-full object-cover" />
        </li>
      ))}
    </ul>
  </Section>

  <!-- Reconhece alguma dessas situações? (queixas do dia a dia; sem cards de diagnóstico, sem CTA) -->
  <Section eyebrow="Você não está só" title="Reconhece alguma dessas situações?">
    <ul role="list" class="mb-10 flex flex-wrap gap-2.5">
      {moments.map((m) => (
        <li class="inline-flex items-center gap-2.5 rounded-full border border-brand-100 bg-paper px-4 py-2.5">
          <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500" aria-hidden="true"></span>
          <span class="font-display text-base leading-snug text-brand-800">{m}</span>
        </li>
      ))}
    </ul>
    <p class="max-w-3xl font-display text-2xl leading-snug text-brand-700">
      Por trás dessas situações, costuma haver uma dificuldade que pode ser compreendida e trabalhada.
    </p>
  </Section>

  <!-- Services -->
  <Section eyebrow="Como posso ajudar" title="Serviços" class="bg-brand-50">
    <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
      {services.map((s) => (
        <ServiceCard title={s.data.title} summary={s.data.tagline ?? s.data.summary} href={`/servicos/${s.id}`} icon={s.data.icon} />
      ))}
    </div>
  </Section>

  <!-- Especialidades (5 cards; no CTA after, per "nothing scary after the diagnoses") -->
  <Section eyebrow="Especialidades" title="Algumas especialidades atendidas">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
      {homeEspecialidades.map((c) => (
        <ConditionCard title={c.data.title} summary={c.data.summary} href={`/condicoes/${c.id}`} compact />
      ))}
    </div>
  </Section>

  <!-- About teaser -->
  <Section class="bg-white">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div class="order-2 lg:order-1">
        <div class="aspect-square max-w-sm overflow-hidden rounded-3xl border border-brand-100 bg-brand-100">
          <img src="/images/thais.jpg" alt={`Foto de ${site.professionalName}, ${site.profession.toLowerCase()} em ${site.city}`} width="900" height="883" loading="lazy" class="h-full w-full object-cover" />
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="eyebrow mb-1.5">Sobre mim</p>
        <h2 class="font-display text-3xl font-semibold text-brand-800 sm:text-4xl">Um olhar atento para cada criança</h2>
        <p class="mt-4 text-ink/90">
          Acredito que toda criança pode aprender quando recebe o apoio certo. Meu trabalho une ciência e
          acolhimento para entender as dificuldades de cada uma e construir, junto com a família e a escola, um
          caminho possível. Atuei como professora em escolas como St. Nicholas, Maple Bear, Beacon, Rio Branco e
          Lourenço Castanho. {site.credentials}
        </p>
        <a href="/sobre" class="mt-6 inline-flex items-center gap-1 font-semibold text-brand-600 hover:text-brand-700">
          Conhecer minha história
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
    </div>
  </Section>

  <!-- FAQ excerpt -->
  <Section eyebrow="Dúvidas frequentes" title="Perguntas que pais costumam fazer" narrow>
    <FAQ items={faqs.slice(0, 5)} includeSchema={false} />
    <p class="mt-6 text-center text-muted">
      <a href="/perguntas-frequentes" class="font-semibold text-brand-600 hover:text-brand-700">Ver todas as perguntas →</a>
    </p>
  </Section>

  <!-- Location -->
  <Section eyebrow="Onde atendo" title="Consultório ou Atendimento Domiciliar" class="bg-white" narrow>
    <p class="mb-8 text-ink/90">
      Os atendimentos particulares acontecem em <strong>{site.city}</strong>, do jeito que for melhor
      para a sua família:
    </p>
    <div class="grid gap-5 sm:grid-cols-2">
      <div class="flex flex-col rounded-2xl border border-brand-100 bg-cream p-6">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
          </svg>
        </span>
        <h3 class="mt-4 font-display text-xl font-semibold text-brand-800">No consultório</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted">
          Em um espaço acolhedor e preparado para crianças, pensado para deixar a sessão leve e segura.
        </p>
      </div>
      <div class="flex flex-col rounded-2xl border border-brand-100 bg-cream p-6">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-accent-300 text-accent-700">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.5c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
        </span>
        <h3 class="mt-4 font-display text-xl font-semibold text-brand-800">Em casa, atendimento domiciliar</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted">
          Na residência do paciente, no ambiente em que a criança já se sente segura e à vontade.
        </p>
      </div>
    </div>
  </Section>

  <CTASection />
</BaseLayout>
