---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTASection from '@/components/CTASection.astro';
import JsonLd from '@/components/JsonLd.astro';
import { site } from '@/config/site';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const updated = d.updatedDate ?? d.pubDate;

const fmt = (dt: Date) => dt.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric', timeZone: 'UTC' });

// Reading time from the raw markdown body (~200 wpm).
const words = (entry.body ?? '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));

// Related posts (other articles, newest first).
const more = (await getCollection('blog'))
  .filter((p) => !p.data.draft && p.id !== entry.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  description: d.description,
  datePublished: d.pubDate.toISOString(),
  dateModified: updated.toISOString(),
  inLanguage: 'pt-BR',
  wordCount: words,
  timeRequired: `PT${readingTime}M`,
  author: { '@id': `${Astro.site!.origin}/#thais` },
  publisher: { '@id': `${Astro.site!.origin}/#practice` },
  mainEntityOfPage: new URL(`/blog/${entry.id}`, Astro.site).href,
  keywords: d.tags.join(', '),
};
---

<BaseLayout
  title={d.title}
  description={d.description}
  path={`/blog/${entry.id}`}
  type="article"
  publishedTime={d.pubDate.toISOString()}
  modifiedTime={updated.toISOString()}
>
  <!-- Reading progress -->
  <div id="read-progress" class="fixed left-0 top-0 z-50 h-1 w-0 bg-accent-500" aria-hidden="true"></div>

  <!-- Article header -->
  <header class="relative overflow-hidden border-b border-brand-100 bg-gradient-to-br from-brand-100 via-cream to-accent-300/25">
    <div class="drift pointer-events-none absolute -right-16 top-0 h-64 w-64 rounded-full bg-accent-300/30 blur-3xl" aria-hidden="true"></div>
    <Breadcrumbs
      items={[
        { label: 'Início', href: '/' },
        { label: 'Artigos', href: '/blog' },
        { label: d.title, href: `/blog/${entry.id}` },
      ]}
    />
    <div class="container-page max-w-3xl pb-12 pt-5">
      {d.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {d.tags.map((t) => (
            <span class="rounded-full border border-brand-200 bg-paper/70 px-3 py-1 text-xs font-semibold text-brand-700">{t}</span>
          ))}
        </div>
      )}
      <h1 class="mt-4 font-display text-4xl font-semibold leading-[1.1] text-brand-800 sm:text-5xl">{d.title}</h1>
      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-muted">
        <span class="flex items-center gap-2">
          <img src="/images/thais.jpg" alt={site.professionalName} width="36" height="36" class="h-9 w-9 rounded-full object-cover ring-2 ring-white" />
          <span class="font-semibold text-brand-800">{site.professionalName}</span>
        </span>
        <span aria-hidden="true">·</span>
        <time datetime={d.pubDate.toISOString()}>{fmt(d.pubDate)}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min de leitura</span>
      </div>
    </div>
  </header>

  <article class="container-page max-w-3xl py-12">
    <div class="prose max-w-none">
      <Content />
    </div>
    {d.updatedDate && (
      <p class="mt-12 border-t border-brand-100 pt-5 text-sm text-muted">
        Última atualização: {fmt(d.updatedDate)}.
      </p>
    )}
  </article>

  <!-- Author card -->
  <div class="container-page max-w-3xl">
    <div class="flex flex-col items-start gap-5 rounded-3xl border border-brand-100 bg-brand-50/60 p-6 sm:flex-row sm:items-center sm:p-7">
      <img src="/images/thais.jpg" alt={`Foto de ${site.professionalName}`} width="72" height="72" class="h-16 w-16 shrink-0 rounded-full object-cover sm:h-[72px] sm:w-[72px]" />
      <div>
        <p class="eyebrow mb-0.5">Sobre a autora</p>
        <p class="font-display text-lg font-semibold text-brand-800">{site.professionalName}</p>
        <p class="mt-1 text-sm leading-relaxed text-muted">
          {site.profession} em {site.city}. {site.credentials}.
        </p>
        <a href="/sobre" class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700">
          Conhecer a Thais
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Continue lendo -->
  {more.length > 0 && (
    <section class="container-page py-16">
      <h2 class="font-display text-2xl font-semibold text-brand-800 sm:text-3xl">Continue lendo</h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-3">
        {more.map((p) => (
          <a
            href={`/blog/${p.id}`}
            class="group flex h-full flex-col rounded-2xl border border-brand-100 bg-white p-6 transition-all hover:-translate-y-1 hover:shadow-lg hover:shadow-brand-900/5"
          >
            <time datetime={p.data.pubDate.toISOString()} class="text-xs font-semibold uppercase tracking-wide text-accent-600">
              {fmt(p.data.pubDate)}
            </time>
            <h3 class="mt-2 font-display text-lg font-semibold text-brand-800 group-hover:text-brand-700">{p.data.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{p.data.description}</p>
            <span class="mt-4 text-sm font-semibold text-brand-600">Ler artigo →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <CTASection />
  <JsonLd schema={articleSchema} />

  <script is:inline>
    (function () {
      var bar = document.getElementById('read-progress');
      if (!bar) return;
      function update() {
        var h = document.documentElement;
        var total = h.scrollHeight - h.clientHeight;
        bar.style.width = (total > 0 ? (h.scrollTop / total) * 100 : 0) + '%';
      }
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    })();
  </script>
</BaseLayout>
