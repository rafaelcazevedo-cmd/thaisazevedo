---
/** Small inline icon set used by service cards. */
interface Props {
  name: 'clipboard' | 'puzzle' | 'school' | 'brain';
  class?: string;
}
const { name, class: className = 'h-6 w-6' } = Astro.props;

const paths: Record<Props['name'], string> = {
  clipboard:
    'M9 5h6a2 2 0 012 2v0a2 2 0 01-2 2H9a2 2 0 01-2-2v0a2 2 0 012-2zM9 5a2 2 0 00-2 2H6a2 2 0 00-2 2v9a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-1a2 2 0 00-2-2',
  puzzle:
    'M11 4a2 2 0 114 0v1a1 1 0 001 1h2a1 1 0 011 1v2a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v2a1 1 0 01-1 1h-2a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-2a1 1 0 011-1h1a2 2 0 100-4H7a1 1 0 01-1-1V8a1 1 0 011-1h2a1 1 0 001-1V4z',
  school:
    'M12 4L3 9l9 5 9-5-9-5zM7 11.5V16c0 1.1 2.24 2.5 5 2.5s5-1.4 5-2.5v-4.5',
  brain:
    'M9.5 4a2.5 2.5 0 00-2.5 2.5A2.5 2.5 0 005 9a2.5 2.5 0 00.5 4.9V16a2 2 0 002 2h.5M9.5 4A1.5 1.5 0 0111 5.5v13M9.5 4h0M14.5 4a2.5 2.5 0 012.5 2.5A2.5 2.5 0 0119 9a2.5 2.5 0 01-.5 4.9V16a2 2 0 01-2 2h-.5',
};
---

<svg
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  viewBox="0 0 24 24"
  aria-hidden="true"
>
  <path stroke-linecap="round" stroke-linejoin="round" d={paths[name]} />
</svg>
