---
/**
 * FAQ accordion (native <details>, no JS) + optional FAQPage JSON-LD.
 * FAQ content is a strong GEO signal: it matches how people prompt AI assistants.
 */
import type { Faq } from '@/data/faqs';
import JsonLd from './JsonLd.astro';

interface Props {
  items: Faq[];
  includeSchema?: boolean;
}
const { items, includeSchema = true } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<div class="divide-y divide-brand-100 overflow-hidden rounded-2xl border border-brand-100 bg-white">
  {
    items.map((f) => (
      <details class="group">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-left font-semibold text-brand-800 hover:bg-brand-50">
          <span>{f.question}</span>
          <svg
            class="h-5 w-5 shrink-0 text-brand-400 transition-transform group-open:rotate-45"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
        </summary>
        <div class="px-5 pb-5 text-ink/90">{f.answer}</div>
      </details>
    ))
  }
</div>

{includeSchema && <JsonLd schema={faqSchema} />}
