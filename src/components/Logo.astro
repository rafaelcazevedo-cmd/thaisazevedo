---
/** Logo: an open book cradling a heart (aprendizagem + acolhimento). */
import { site } from '@/config/site';
interface Props {
  variant?: 'dark' | 'light';
  class?: string;
}
const { variant = 'dark', class: className = '' } = Astro.props;
const nameColor = variant === 'light' ? 'text-white' : 'text-brand-700';
const subColor = variant === 'light' ? 'text-brand-100' : 'text-muted';
---

<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <svg viewBox="0 0 48 48" class="h-9 w-9 shrink-0" aria-hidden="true">
    <circle cx="24" cy="24" r="24" fill="var(--color-brand-700)"></circle>
    <path d="M10 31 C16 28 21 28 24 30.5 C27 28 32 28 38 31 L38 39 C32 36 27 36 24 38.5 C21 36 16 36 10 39 Z" fill="var(--color-cream)"></path>
    <path d="M24 30.5 V38.5" stroke="var(--color-brand-300)" stroke-width="1.3"></path>
    <path d="M24 14 C22 10.5 16.5 11.5 16.5 15.5 C16.5 19 21 22 24 24 C27 22 31.5 19 31.5 15.5 C31.5 11.5 26 10.5 24 14 Z" fill="var(--color-accent-400)"></path>
  </svg>
  <span class="flex flex-col leading-none">
    <span class={`font-display text-lg font-semibold ${nameColor}`}>{site.brand}</span>
    <span class={`text-[0.7rem] font-medium uppercase tracking-wide ${subColor}`}>{site.profession}</span>
  </span>
</span>
