---
/** Placeholder SVG wordmark. Thais can swap this for a real logo later. */
import { site } from '@/config/site';
interface Props {
  variant?: 'dark' | 'light';
  class?: string;
}
const { variant = 'dark', class: className = '' } = Astro.props;
const nameColor = variant === 'light' ? 'text-white' : 'text-brand-700';
const subColor = variant === 'light' ? 'text-brand-100' : 'text-muted';
---

<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <svg viewBox="0 0 40 40" class="h-9 w-9 shrink-0" aria-hidden="true">
    <circle cx="20" cy="20" r="20" fill="var(--color-brand-500)"></circle>
    <path
      d="M12 26c0-6 3.6-9 8-9s8 3 8 9M20 17a4 4 0 100-8 4 4 0 000 8z"
      fill="none"
      stroke="white"
      stroke-width="2.2"
      stroke-linecap="round"
    ></path>
    <path d="M27 13c2.5 0 4 1.6 4 3.6S29.5 20 27 20" fill="none" stroke="var(--color-accent-400)" stroke-width="2.2" stroke-linecap="round"></path>
  </svg>
  <span class="flex flex-col leading-none">
    <span class={`font-display text-lg font-semibold ${nameColor}`}>{site.brand}</span>
    <span class={`text-[0.7rem] font-medium uppercase tracking-wide ${subColor}`}>{site.profession}</span>
  </span>
</span>
