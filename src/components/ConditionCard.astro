---
interface Props {
  title: string;
  summary: string;
  href: string;
}
const { title, summary, href } = Astro.props;
---

<a
  href={href}
  class="group flex h-full flex-col rounded-2xl border border-brand-100 bg-white p-6 transition-all hover:-translate-y-1 hover:border-accent-400 hover:shadow-lg hover:shadow-brand-900/5"
>
  <h3 class="font-display text-lg font-semibold text-brand-800 group-hover:text-brand-700">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted line-clamp-2">{summary}</p>
  <span class="mt-4 text-sm font-semibold text-accent-600">Entenda os sinais →</span>
</a>
