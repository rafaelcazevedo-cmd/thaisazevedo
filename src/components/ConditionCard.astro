---
import Card from './Card.astro';
import CardLink from './CardLink.astro';

interface Props {
  title: string;
  summary: string;
  href: string;
  /** Title-only card (no summary) for dense overviews like the homepage. */
  compact?: boolean;
}
const { title, summary, href, compact = false } = Astro.props;
---

<Card href={href} ariaLabel={title}>
  <h3 class="font-display text-lg font-semibold text-brand-800 group-hover:text-brand-700">{title}</h3>
  {!compact && <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{summary}</p>}
  <CardLink label="Entenda os sinais" marginClass={compact ? 'mt-auto pt-4' : 'mt-4'} />
</Card>
