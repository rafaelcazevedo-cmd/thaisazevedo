---
/**
 * Photo card that quietly flips on click to reveal a short line about the skill.
 * Hidden by design: no visible affordance — discovered by interacting. Keeps the
 * original gallery look (rounded photo + label below). Accessible (real <button>,
 * aria-pressed, off-face aria-hidden), reduced-motion aware (instant), no-JS safe
 * (front photo shows), and always loads unflipped.
 */
interface Props {
  src: string;
  alt: string;
  label: string;
  back: string;
}
const { src, alt, label, back } = Astro.props;
---

<figure class="flip-figure">
  <button type="button" class="flip-card" data-flip aria-pressed="false" aria-label={`${label}: ver o que trabalhamos`}>
    <span class="flip-inner">
      <span class="flip-face flip-front">
        <img src={src} alt={alt} width="640" height="800" loading="eager" decoding="sync" />
      </span>
      <span class="flip-face flip-back" aria-hidden="true">
        <span class="flip-back-text">{back}</span>
      </span>
    </span>
  </button>
  <figcaption class="flip-caption">{label}</figcaption>
</figure>

<style>
  .flip-figure {
    margin: 0;
  }
  .flip-card {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    perspective: 1000px;
    -webkit-tap-highlight-color: transparent;
  }
  .flip-card:focus-visible {
    outline: 3px solid var(--color-accent-500);
    outline-offset: 3px;
    border-radius: 1rem;
  }
  .flip-inner {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    transition: transform 0.55s cubic-bezier(0.4, 0.1, 0.2, 1);
    transform-style: preserve-3d;
  }
  .flip-card[aria-pressed='true'] .flip-inner {
    transform: rotateY(180deg);
  }
  .flip-face {
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    border: 1px solid var(--color-brand-100);
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.06);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .flip-front img {
    display: block;
    height: 100%;
    width: 100%;
    object-fit: cover;
    border-radius: 1rem;
  }
  .flip-back {
    transform: rotateY(180deg);
    background: var(--color-brand-700);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.1rem;
  }
  .flip-back-text {
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgb(255 255 255 / 0.95);
  }
  .flip-caption {
    margin-top: 0.5rem;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-brand-700);
  }
  @media (prefers-reduced-motion: reduce) {
    .flip-inner {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-flip]').forEach((btn) => {
    const front = btn.querySelector('.flip-front');
    const back = btn.querySelector('.flip-back');
    btn.addEventListener('click', () => {
      const next = btn.getAttribute('aria-pressed') !== 'true';
      btn.setAttribute('aria-pressed', String(next));
      // Keep only the visible face in the accessibility tree.
      front?.setAttribute('aria-hidden', String(next));
      back?.setAttribute('aria-hidden', String(!next));
    });
  });
</script>
