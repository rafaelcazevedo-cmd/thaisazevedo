---
// Self-hosted variable fonts (no external CDN → fast + LGPD-friendly).
import '@fontsource-variable/fraunces';
import '@fontsource-variable/fraunces/opsz-italic.css';
import '@fontsource-variable/hanken-grotesk';
import '@/styles/global.css';
import BaseHead from '@/components/BaseHead.astro';
import SiteSchema from '@/components/SiteSchema.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import FloatingWhatsApp from '@/components/FloatingWhatsApp.astro';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}
const props = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead {...props} />
    <SiteSchema />
    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <a
      href="#conteudo"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-white focus:px-4 focus:py-2 focus:text-brand-700 focus:shadow"
      >Pular para o conteúdo</a
    >
    <Header />
    <main id="conteudo">
      <slot />
    </main>
    <Footer />
    <FloatingWhatsApp />

    <script is:inline>
      // Progressive scroll reveal: only hides elements once JS confirms it can reveal them.
      (function () {
        var root = document.documentElement;
        if (!('IntersectionObserver' in window) ||
            window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          return;
        }
        root.classList.add('js');
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
        document.querySelectorAll('[data-reveal]').forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
